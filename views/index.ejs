<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-black py-10">

    <div class="w-full max-w-7xl mx-auto px-6">

        <!-- Form Section -->
        <div class="max-w-md mx-auto bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">

            <div class="text-center mb-8">

                <h1 class="text-4xl font-bold text-white mb-2">
                    Resume Analyzer
                </h1>

                <p class="text-slate-400">
                    Compare your resume against real job requirements using AI
                </p>

            </div>

            <form
                action="/compare"
                method="POST"
                enctype="multipart/form-data"
                class="space-y-5"
            >

                <div>
                    <label class="block text-slate-300 mb-2">
                        Target Role
                    </label>

                    <input
                        type="text"
                        name="role"
                        placeholder="e.g. Backend Developer"
                        class="w-full bg-slate-900/80 border border-slate-700 rounded-xl px-4 py-3 text-white outline-none focus:border-cyan-500 transition"
                    >
                </div>

                <div>
                    <label class="block text-slate-300 mb-2">
                        Upload Resume
                    </label>

                    <input
                        type="file"
                        name="resume"
                        class="w-full text-slate-300 file:bg-cyan-600 file:text-white file:border-0 file:px-4 file:py-2 file:rounded-lg file:cursor-pointer"
                    >
                </div>

                <button
                    type="submit"
                    class="w-full py-3 rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold hover:scale-[1.02] transition-all duration-200 shadow-lg shadow-cyan-500/20"
                >
                    Analyze Resume
                </button>

            </form>

        </div>

        <!-- Results Section -->
        <% if(typeof final_output !== 'undefined' && final_output) { %>

        <div class="mt-12">

            <div class="text-center mb-8">

                <h1 class="text-4xl font-bold text-white mb-4">
                    Analysis Result
                </h1>

                <div class="inline-block px-6 py-3 bg-slate-800 rounded-2xl">
                    <span class="text-white text-xl font-semibold">
                        Overall Score:
                    </span>

                    <span class="text-green-400 text-3xl font-bold ml-2">
                        <%= final_output.overall_score.toFixed(2) %>%
                    </span>
                </div>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

                <!-- Resume Skills -->
                <div class="bg-slate-800/80 backdrop-blur-lg p-6 rounded-2xl">
                    <h2 class="text-cyan-400 text-xl font-bold mb-4">
                        Resume Skills
                    </h2>

                    <ul class="space-y-2 text-slate-200">
                        <% resume_skills.forEach(skill => { %>
                            <li>• <%= skill %></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Job Skills -->
                <div class="bg-slate-800/80 backdrop-blur-lg p-6 rounded-2xl">
                    <h2 class="text-yellow-400 text-xl font-bold mb-4">
                        Job Skills Required
                    </h2>

                    <ul class="space-y-2 text-slate-200">
                        <% technicalSkills.forEach(skill => { %>
                            <li>• <%= skill %></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Exact Matches -->
                <div class="bg-slate-800/80 backdrop-blur-lg p-6 rounded-2xl">
                    <h2 class="text-green-400 text-xl font-bold mb-4">
                        Exact Matches
                    </h2>

                    <ul class="space-y-2 text-slate-200">
                        <% final_output.exact_matches.forEach(match => { %>
                            <li>• <%= match.skill %></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Ontology Matches -->
                <div class="bg-slate-800/80 backdrop-blur-lg p-6 rounded-2xl">
                    <h2 class="text-purple-400 text-xl font-bold mb-4">
                        Ontology Matches
                    </h2>

                    <ul class="space-y-2 text-slate-200">
                        <% final_output.ontology_matches.forEach(match => { %>
                            <li>
                                <span class="text-purple-300">
                                    <%= match.job_skill %>
                                </span>
                                →
                                <span class="text-cyan-300">
                                    <%= match.resume_skill %>
                                </span>
                            </li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Semantic Matches -->
                <div class="bg-slate-800/80 backdrop-blur-lg p-6 rounded-2xl">
                    <h2 class="text-blue-400 text-xl font-bold mb-4">
                        Semantic Matches
                    </h2>

                    <ul class="space-y-2 text-slate-200">
                        <% final_output.semantic_matches.forEach(match => { %>
                            <li>
                                <span class="text-blue-300">
                                    <%= match.job_skill %>
                                </span>
                                →
                                <span class="text-cyan-300">
                                    <%= match.resume_skill %>
                                </span>
                                <span class="text-green-400">
                                    (<%= match.score %>)
                                </span>
                            </li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Missing Skills -->
                <div class="bg-slate-800/80 backdrop-blur-lg p-6 rounded-2xl">
                    <h2 class="text-red-400 text-xl font-bold mb-4">
                        Missing Skills
                    </h2>

                    <ul class="space-y-2 text-slate-200">
                        <% final_output.missing.forEach(skill => { %>
                            <li>• <%= skill %></li>
                        <% }) %>
                    </ul>
                </div>

            </div>

        </div>

        <% } %>

    </div>

</body>
</html>